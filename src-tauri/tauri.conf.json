{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Corkscrew",
  "version": "0.5.1",
  "identifier": "com.cashconway.corkscrew",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Corkscrew",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 22, "y": 26 },
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    },
    "category": "Game",
    "shortDescription": "Mod manager for CrossOver/Wine games",
    "longDescription": "Corkscrew is a native mod manager for games running through Wine-based compatibility layers (CrossOver, Whisky, Proton, Lutris) on macOS and Linux. Install, manage, and organize mods with Nexus Mods integration."
  }
}
